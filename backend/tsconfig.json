{
	"compilerOptions": {
		"target": "es2020",
		"module": "commonjs",
		"rootDir": "./",
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["node", "jest"],
		"typeRoots": ["./node_modules/@types", "./src/types"]
	},
	"include": ["src/**/*", "__tests__/**/*"],
	"exclude": ["node_modules", "dist"]
}
